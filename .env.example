.env.example for local development:
Place a file named `.env` in the project root (already gitignored).

# ===== Firebase =====
FIREBASE_CONFIG_PATH=firebase-service-account.json

# ===== JWT =====
JWT_SECRET=yourSuperSecretKeyThatIsAtLeast256BitsLongForHmacSHA256Algorithm2024!

# ===== Docker Hub =====
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password

# ===== Database (for staging/prod) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devopsdb
DB_USERNAME=devops
DB_PASSWORD=devops_password
