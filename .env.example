Place a file named `.env` in the project root (already gitignored).

# Firebase
FIREBASE_CONFIG_PATH=firebase-service-account.json

# JWT
JWT_SECRET=yourSuperSecretKeyThatIsAtLeast256BitsLongForHmacSHA256Algorithm2024!

# Jenkins API (for historical backfill)
JENKINS_BASE_URL=http://localhost:8080
JENKINS_USERNAME=your_jenkins_username
JENKINS_API_TOKEN=your_jenkins_api_token
JENKINS_BACKFILL_STARTUP_ENABLED=true
JENKINS_BACKFILL_DEFAULT_PER_JOB_LIMIT=500
JENKINS_BACKFILL_SKIP_IF_RECENT_MINUTES=360

# Docker Hub
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_password
