# Copy this file to `.env` and replace all placeholder values.

# Firebase
FIREBASE_CONFIG_PATH=/run/secrets/firebase/service-account.json
FIREBASE_SERVICE_ACCOUNT_FILE=./secrets/firebase-service-account.json

# JWT
JWT_SECRET=replace_with_a_minimum_32_character_random_secret

# Webhook Security
JENKINS_WEBHOOK_SECRET=replace_with_long_random_shared_secret

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Jenkins API (for historical backfill and links)
JENKINS_BASE_URL=http://localhost:8080
JENKINS_USERNAME=your_jenkins_username
JENKINS_API_TOKEN=your_jenkins_api_token
JENKINS_BACKFILL_STARTUP_ENABLED=true
JENKINS_BACKFILL_DEFAULT_PER_JOB_LIMIT=500
JENKINS_BACKFILL_SKIP_IF_RECENT_MINUTES=360

# Frontend build-time links
VITE_JENKINS_BASE_URL=http://localhost:8080
GITHUB_REPO_URL=https://github.com/Prasanth631/Capstone

# Docker Hub
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_access_token

# Grafana (docker-compose)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_with_strong_password
