pipeline {
    agent any

    tools {
        maven 'MAVEN_HOME'
        jdk 'JDK22'
    }

    environment {
        DOCKER_IMAGE       = 'prasanth631/devops-platform'
        FRONTEND_IMAGE     = 'prasanth631/devops-frontend'
        DOCKER_CREDS       = credentials('dockerhub-credentials')
        WEBHOOK_URL        = 'http://localhost:8082/api/webhook/jenkins'
        DOCKER_BUILDKIT    = '1'   // Enable BuildKit for faster, parallel layer builds
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        // ===== STAGE 1: Checkout =====
        stage('Checkout') {
            steps {
                notifyWebhook('Checkout', 'IN_PROGRESS')
                deleteDir()
                checkout scm
                notifyWebhook('Checkout', 'SUCCESS')
            }
        }

        // ===== STAGE 2: Build =====
        stage('Build') {
            steps {
                notifyWebhook('Build', 'IN_PROGRESS')
                dir('backend') {
                    bat 'mvn clean package -DskipTests -B'
                }
                notifyWebhook('Build', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Build', 'FAILURE')
                }
            }
        }

        // ===== STAGE 3: Unit & Integration Tests =====
        stage('Unit & Integration Tests') {
            steps {
                notifyWebhook('Unit & Integration Tests', 'IN_PROGRESS')
                dir('backend') {
                    bat 'mvn clean test -B'
                }
                notifyWebhook('Unit & Integration Tests', 'SUCCESS')
            }
            post {
                always {
                    dir('backend') {
                        junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
                        jacoco execPattern: '**/target/jacoco.exec'
                    }
                }
                failure {
                    notifyWebhook('Unit & Integration Tests', 'FAILURE')
                }
            }
        }

        // ===== STAGE 4: Docker Build & Push =====
        stage('Docker Build & Push') {
            steps {
                notifyWebhook('Docker Build & Push', 'IN_PROGRESS')

                // Login to Docker Hub
                bat "docker login -u %DOCKER_CREDS_USR% -p %DOCKER_CREDS_PSW%"

                // Backend Docker image
                dir('backend') {
                    bat "docker build -t %DOCKER_IMAGE%:%BUILD_NUMBER% -t %DOCKER_IMAGE%:latest ."
                }

                // Frontend Docker image
                dir('frontend') {
                    bat "docker build -t %FRONTEND_IMAGE%:%BUILD_NUMBER% -t %FRONTEND_IMAGE%:latest ."
                }

                // Push backend images
                bat "docker push %DOCKER_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %DOCKER_IMAGE%:latest"

                // Push frontend images
                bat "docker push %FRONTEND_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %FRONTEND_IMAGE%:latest"

                notifyWebhook('Docker Build & Push', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Docker Build & Push', 'FAILURE')
                }
            }
        }

        // ===== STAGE 5: Deploy to Dev =====
        stage('Deploy to Dev') {
            steps {
                notifyWebhook('Deploy to Dev', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat "kubectl apply -f k8s/dev/ --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-platform devops-platform=%DOCKER_IMAGE%:%BUILD_NUMBER% -n dev --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-platform -n dev --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Deploy to Dev', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Deploy to Dev', 'FAILURE')
                }
            }
        }

        // ===== STAGE 6: Smoke Test =====
        stage('Smoke Test') {
            steps {
                notifyWebhook('Smoke Test', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat "kubectl wait --for=condition=ready pod -l app=devops-platform -n dev --timeout=120s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Smoke Test', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Smoke Test', 'FAILURE')
                }
            }
        }

        // ===== STAGE 7: Deploy to Staging =====
        stage('Deploy to Staging') {
            steps {
                notifyWebhook('Deploy to Staging', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat "kubectl apply -f k8s/staging/ --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-platform devops-platform=%DOCKER_IMAGE%:%BUILD_NUMBER% -n staging --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-platform -n staging --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Deploy to Staging', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Deploy to Staging', 'FAILURE')
                }
            }
        }

        // ===== STAGE 8: Manual Approval =====
        stage('Manual Approval') {
            steps {
                notifyWebhook('Manual Approval', 'IN_PROGRESS')
                input message: 'Deploy to Production?', ok: 'Approve'
                notifyWebhook('Manual Approval', 'SUCCESS')
            }
        }

        // ===== STAGE 9: Deploy to Production =====
        stage('Deploy to Production') {
            steps {
                notifyWebhook('Deploy to Production', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat "kubectl apply -f k8s/production/ --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-platform devops-platform=%DOCKER_IMAGE%:%BUILD_NUMBER% -n production --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-platform -n production --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Deploy to Production', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Deploy to Production', 'FAILURE')
                    // Auto-rollback on production failure
                    withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                        bat "kubectl rollout undo deployment/devops-platform -n production --kubeconfig=\"%KUBECONFIG%\""
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
        always {
            echo 'Pipeline execution finished.'
        }
    }
}

// ───── Helper: Send webhook notification to Spring Boot ─────
def notifyWebhook(String stageName, String status) {
    try {
        def payload = """{
            "buildNumber": ${env.BUILD_NUMBER},
            "jobName": "${env.JOB_NAME}",
            "stage": "${stageName}",
            "status": "${status}",
            "duration": ${currentBuild.duration},
            "gitBranch": "${env.GIT_BRANCH ?: 'unknown'}",
            "gitCommit": "${env.GIT_COMMIT ?: 'unknown'}",
            "triggerType": "${currentBuild.getBuildCauses()[0]?.shortDescription ?: 'unknown'}",
            "timestamp": ${System.currentTimeMillis()}
        }"""

        httpRequest(
            url: env.WEBHOOK_URL,
            httpMode: 'POST',
            contentType: 'APPLICATION_JSON',
            requestBody: payload,
            validResponseCodes: '100:599',  // Never fail the pipeline on webhook errors
            quiet: true
        )
    } catch (Exception e) {
        echo "Webhook notification failed for ${stageName}: ${e.message}"
    }
}
