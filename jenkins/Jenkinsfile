pipeline {
    agent any

    tools {
        maven 'MAVEN_HOME'
        jdk 'JDK22'
    }

    parameters {
        string(name: 'BACKEND_IMAGE', defaultValue: 'prasanth631/devops-platform', description: 'Docker image repository for backend')
        string(name: 'FRONTEND_IMAGE', defaultValue: 'prasanth631/devops-frontend', description: 'Docker image repository for frontend')
        string(name: 'WEBHOOK_URL', defaultValue: 'http://localhost:8082/api/webhook/jenkins', description: 'Signed Jenkins webhook endpoint')
        string(name: 'API_TEST_SUITE', defaultValue: 'DashboardControllerIntegrationTest,PipelineWebhookControllerIntegrationTest', description: 'Comma-separated Maven integration tests for API stage')
        string(name: 'DEV_NAMESPACE', defaultValue: 'dev', description: 'Kubernetes namespace for dev environment')
        string(name: 'STAGING_NAMESPACE', defaultValue: 'staging', description: 'Kubernetes namespace for staging environment')
        string(name: 'PRODUCTION_NAMESPACE', defaultValue: 'production', description: 'Kubernetes namespace for production environment')
        string(name: 'MANIFEST_FILE', defaultValue: 'manifests.yaml', description: 'Manifest file name used in each k8s/<env>/ directory')
    }

    environment {
        DOCKER_IMAGE        = "${params.BACKEND_IMAGE}"
        FRONTEND_IMAGE      = "${params.FRONTEND_IMAGE}"
        WEBHOOK_URL         = "${params.WEBHOOK_URL}"
        API_TEST_SUITE      = "${params.API_TEST_SUITE}"
        DEV_NAMESPACE       = "${params.DEV_NAMESPACE}"
        STAGING_NAMESPACE   = "${params.STAGING_NAMESPACE}"
        PRODUCTION_NAMESPACE = "${params.PRODUCTION_NAMESPACE}"
        MANIFEST_FILE       = "${params.MANIFEST_FILE}"
        DOCKER_BUILDKIT     = '1'
        WEBHOOK_TOKEN       = credentials('jenkins-webhook-secret')
    }

    options {
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                notifyWebhook('Checkout', 'IN_PROGRESS')
                deleteDir()
                checkout scm
                notifyWebhook('Checkout', 'SUCCESS')
            }
            post {
                failure { notifyWebhook('Checkout', 'FAILURE') }
            }
        }

        stage('Build') {
            steps {
                notifyWebhook('Build', 'IN_PROGRESS')
                dir('backend') {
                    bat 'mvn -B clean package -DskipTests'
                }
                notifyWebhook('Build', 'SUCCESS')
            }
            post {
                failure { notifyWebhook('Build', 'FAILURE') }
            }
        }

        stage('Unit & Integration Tests') {
            steps {
                notifyWebhook('Unit & Integration Tests', 'IN_PROGRESS')
                dir('backend') {
                    bat 'mvn -B test'
                }
                notifyWebhook('Unit & Integration Tests', 'SUCCESS')
            }
            post {
                always {
                    dir('backend') {
                        junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
                        jacoco execPattern: '**/target/jacoco.exec'
                    }
                }
                failure { notifyWebhook('Unit & Integration Tests', 'FAILURE') }
            }
        }

        stage('Static Analysis') {
            steps {
                notifyWebhook('Static Analysis', 'IN_PROGRESS')
                dir('backend') {
                    bat 'mvn -B -DskipTests verify -Djacoco.skip=true'
                }
                notifyWebhook('Static Analysis', 'SUCCESS')
            }
            post {
                failure { notifyWebhook('Static Analysis', 'FAILURE') }
            }
        }

        stage('API Tests') {
            steps {
                notifyWebhook('API Tests', 'IN_PROGRESS')
                dir('backend') {
                    bat "mvn -B -Dtest=%API_TEST_SUITE% test"
                }
                notifyWebhook('API Tests', 'SUCCESS')
            }
            post {
                failure { notifyWebhook('API Tests', 'FAILURE') }
            }
        }

        stage('Docker Build & Push') {
            steps {
                notifyWebhook('Docker Build & Push', 'IN_PROGRESS')

                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    bat '@echo %DOCKER_PASS% | docker login --username %DOCKER_USER% --password-stdin'
                }

                dir('backend') {
                    bat "docker build -t %DOCKER_IMAGE%:%BUILD_NUMBER% -t %DOCKER_IMAGE%:latest ."
                }

                dir('frontend') {
                    bat "docker build -t %FRONTEND_IMAGE%:%BUILD_NUMBER% -t %FRONTEND_IMAGE%:latest ."
                }

                bat "docker push %DOCKER_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %DOCKER_IMAGE%:latest"
                bat "docker push %FRONTEND_IMAGE%:%BUILD_NUMBER%"
                bat "docker push %FRONTEND_IMAGE%:latest"
                bat 'docker logout'

                notifyWebhook('Docker Build & Push', 'SUCCESS')
            }
            post {
                failure { notifyWebhook('Docker Build & Push', 'FAILURE') }
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                notifyWebhook('Security Scan (Trivy)', 'IN_PROGRESS')
                script {
                    // Install Trivy if not already installed
                    def trivyInstalled = bat(returnStatus: true, script: 'trivy --version >nul 2>&1')
                    if (trivyInstalled != 0) {
                        echo 'Trivy not found. Installing via winget...'
                            writeFile file: 'install-trivy.ps1', text: '''
$url = "https://github.com/aquasecurity/trivy/releases/download/v0.70.0/trivy_0.70.0_windows-64bit.zip"
$dest = "$env:TEMP\\trivy.zip"
$trivyDir = "C:\\trivy"
if (-not (Test-Path $trivyDir)) { New-Item -ItemType Directory -Path $trivyDir | Out-Null }
Invoke-WebRequest -Uri $url -OutFile $dest -UseBasicParsing
Expand-Archive -Path $dest -DestinationPath $trivyDir -Force
$envPath = [Environment]::GetEnvironmentVariable("PATH", "Machine")
if ($envPath -notlike "*C:\\trivy*") {
    [Environment]::SetEnvironmentVariable("PATH", $envPath + ";C:\\trivy", "Machine")
}
Write-Host "Trivy installed successfully"
                            '''
                            bat 'powershell -NoProfile -ExecutionPolicy Bypass -File install-trivy.ps1'
                    }

                    // Create reports directory
                    bat 'if not exist trivy-reports mkdir trivy-reports'

                    // Scan backend image
                    def backendScanExit = bat(returnStatus: true, script: """
                        C:\\trivy\\trivy.exe image ^
                            --format json ^
                            --output trivy-reports\\backend-scan.json ^
                            --severity CRITICAL,HIGH,MEDIUM,LOW ^
                            --no-progress ^
                            %DOCKER_IMAGE%:%BUILD_NUMBER%
                    """)

                    // Scan frontend image
                    def frontendScanExit = bat(returnStatus: true, script: """
                        C:\\trivy\\trivy.exe image ^
                            --format json ^
                            --output trivy-reports\\frontend-scan.json ^
                            --severity CRITICAL,HIGH,MEDIUM,LOW ^
                            --no-progress ^
                            %FRONTEND_IMAGE%:%BUILD_NUMBER%
                    """)

                    // Parse JSON results and send to backend dashboard API
                    writeFile file: 'send-trivy.ps1', text: '''
function Parse-TrivyJson {
    param([string]$FilePath, [string]$ImageName)
    if (-not (Test-Path $FilePath)) {
        return @{ image=$ImageName; criticalCount=0; highCount=0; mediumCount=0; lowCount=0; status='NO_FILE' }
    }
    try {
        $json = Get-Content $FilePath -Raw | ConvertFrom-Json
        $critical=0; $high=0; $medium=0; $low=0
        foreach ($result in $json.Results) {
            foreach ($vuln in $result.Vulnerabilities) {
                switch ($vuln.Severity) {
                    'CRITICAL' { $critical++ }
                    'HIGH'     { $high++ }
                    'MEDIUM'   { $medium++ }
                    'LOW'      { $low++ }
                }
            }
        }
        return @{ image=$ImageName; criticalCount=$critical; highCount=$high; mediumCount=$medium; lowCount=$low; scannedAt=[DateTimeOffset]::UtcNow.ToUnixTimeMilliseconds(); status='COMPLETED' }
    } catch {
        return @{ image=$ImageName; criticalCount=0; highCount=0; mediumCount=0; lowCount=0; error=$_.Exception.Message }
    }
}
$backendImage  = $env:DOCKER_IMAGE + ":" + $env:BUILD_NUMBER
$frontendImage = $env:FRONTEND_IMAGE + ":" + $env:BUILD_NUMBER
$backend  = Parse-TrivyJson -FilePath "trivy-reports\\backend-scan.json"  -ImageName $backendImage
$frontend = Parse-TrivyJson -FilePath "trivy-reports\\frontend-scan.json" -ImageName $frontendImage
Write-Host "Backend:  CRITICAL=$($backend.criticalCount)  HIGH=$($backend.highCount)  MEDIUM=$($backend.mediumCount)"
Write-Host "Frontend: CRITICAL=$($frontend.criticalCount) HIGH=$($frontend.highCount) MEDIUM=$($frontend.mediumCount)"
$webhookUrl = $env:WEBHOOK_URL -replace '/api/webhook/jenkins', '/api/security/scan-result'
try {
    Invoke-RestMethod -Method POST -Uri $webhookUrl -Body ($backend  | ConvertTo-Json -Depth 10) -ContentType 'application/json' -TimeoutSec 10 | Out-Null
    Invoke-RestMethod -Method POST -Uri $webhookUrl -Body ($frontend | ConvertTo-Json -Depth 10) -ContentType 'application/json' -TimeoutSec 10 | Out-Null
    Write-Host "Scan results sent to dashboard successfully"
} catch {
    Write-Warning "Could not send scan results to dashboard: $_"
}
                    '''
                    bat 'powershell -NoProfile -ExecutionPolicy Bypass -File send-trivy.ps1'
                }
                notifyWebhook('Security Scan (Trivy)', 'SUCCESS')
            }
            post {
                always {
                    archiveArtifacts artifacts: 'trivy-reports/**/*.json', allowEmptyArchive: true
                }
                failure { notifyWebhook('Security Scan (Trivy)', 'FAILURE') }
            }
        }

        stage('Deploy to Dev') {
            steps {
                notifyWebhook('Deploy to Dev', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat 'if not exist k8s\\dev\\%MANIFEST_FILE% (echo [ERROR] Missing manifest: k8s/dev/%MANIFEST_FILE% & exit /b 1)'
                    bat 'kubectl get namespace %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%" || kubectl create namespace %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat 'kubectl get secret app-secrets -n %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat 'kubectl get secret firebase-service-account -n %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat "kubectl apply -f k8s/dev/%MANIFEST_FILE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-platform devops-platform=%DOCKER_IMAGE%:%BUILD_NUMBER% -n %DEV_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-frontend devops-frontend=%FRONTEND_IMAGE%:%BUILD_NUMBER% -n %DEV_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-platform -n %DEV_NAMESPACE% --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-frontend -n %DEV_NAMESPACE% --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Deploy to Dev', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Deploy to Dev', 'FAILURE')
                    withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                        bat 'kubectl get pods -n %DEV_NAMESPACE% -o wide --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-platform -n %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-frontend -n %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl get events -n %DEV_NAMESPACE% --sort-by=.lastTimestamp --kubeconfig="%KUBECONFIG%" || exit /b 0'
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                notifyWebhook('Smoke Test', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat "kubectl wait --for=condition=available deployment/devops-platform -n %DEV_NAMESPACE% --timeout=180s --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl wait --for=condition=available deployment/devops-frontend -n %DEV_NAMESPACE% --timeout=180s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Smoke Test', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Smoke Test', 'FAILURE')
                    withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                        bat 'kubectl get pods -n %DEV_NAMESPACE% -o wide --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-platform -n %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-frontend -n %DEV_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl get events -n %DEV_NAMESPACE% --sort-by=.lastTimestamp --kubeconfig="%KUBECONFIG%" || exit /b 0'
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            steps {
                notifyWebhook('Deploy to Staging', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat 'if not exist k8s\\staging\\%MANIFEST_FILE% (echo [ERROR] Missing manifest: k8s/staging/%MANIFEST_FILE% & exit /b 1)'
                    bat 'kubectl get namespace %STAGING_NAMESPACE% --kubeconfig="%KUBECONFIG%" || kubectl create namespace %STAGING_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat 'kubectl get secret app-secrets -n %STAGING_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat 'kubectl get secret firebase-service-account -n %STAGING_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat "kubectl apply -f k8s/staging/%MANIFEST_FILE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-platform devops-platform=%DOCKER_IMAGE%:%BUILD_NUMBER% -n %STAGING_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-frontend devops-frontend=%FRONTEND_IMAGE%:%BUILD_NUMBER% -n %STAGING_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-platform -n %STAGING_NAMESPACE% --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-frontend -n %STAGING_NAMESPACE% --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Deploy to Staging', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Deploy to Staging', 'FAILURE')
                    withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                        bat 'kubectl get pods -n %STAGING_NAMESPACE% -o wide --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-platform -n %STAGING_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-frontend -n %STAGING_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl get events -n %STAGING_NAMESPACE% --sort-by=.lastTimestamp --kubeconfig="%KUBECONFIG%" || exit /b 0'
                    }
                }
            }
        }


        stage('Deploy to Production') {
            steps {
                notifyWebhook('Deploy to Production', 'IN_PROGRESS')
                withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                    bat 'if not exist k8s\\production\\%MANIFEST_FILE% (echo [ERROR] Missing manifest: k8s/production/%MANIFEST_FILE% & exit /b 1)'
                    bat 'kubectl get namespace %PRODUCTION_NAMESPACE% --kubeconfig="%KUBECONFIG%" || kubectl create namespace %PRODUCTION_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat 'kubectl get secret app-secrets -n %PRODUCTION_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat 'kubectl get secret firebase-service-account -n %PRODUCTION_NAMESPACE% --kubeconfig="%KUBECONFIG%"'
                    bat "kubectl apply -f k8s/production/%MANIFEST_FILE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-platform devops-platform=%DOCKER_IMAGE%:%BUILD_NUMBER% -n %PRODUCTION_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl set image deployment/devops-frontend devops-frontend=%FRONTEND_IMAGE%:%BUILD_NUMBER% -n %PRODUCTION_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-platform -n %PRODUCTION_NAMESPACE% --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                    bat "kubectl rollout status deployment/devops-frontend -n %PRODUCTION_NAMESPACE% --timeout=300s --kubeconfig=\"%KUBECONFIG%\""
                }
                notifyWebhook('Deploy to Production', 'SUCCESS')
            }
            post {
                failure {
                    notifyWebhook('Deploy to Production', 'FAILURE')
                    withCredentials([file(credentialsId: 'kubeconfig-credential', variable: 'KUBECONFIG')]) {
                        bat 'kubectl get pods -n %PRODUCTION_NAMESPACE% -o wide --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-platform -n %PRODUCTION_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl describe deployment/devops-frontend -n %PRODUCTION_NAMESPACE% --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat 'kubectl get events -n %PRODUCTION_NAMESPACE% --sort-by=.lastTimestamp --kubeconfig="%KUBECONFIG%" || exit /b 0'
                        bat returnStatus: true, script: "kubectl rollout undo deployment/devops-platform -n %PRODUCTION_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                        bat returnStatus: true, script: "kubectl rollout undo deployment/devops-frontend -n %PRODUCTION_NAMESPACE% --kubeconfig=\"%KUBECONFIG%\""
                    }
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully'
        }
        failure {
            echo 'Pipeline failed'
        }
        always {
            echo 'Pipeline execution finished'
        }
    }
}

def notifyWebhook(String stageName, String status) {
    try {
        def testData = 'null'
        if (stageName == 'Unit & Integration Tests' || stageName == 'API Tests') {
            try {
                def total = 0, failed = 0, skipped = 0
                def reports = findFiles(glob: 'backend/target/surefire-reports/*.xml')
                for (report in reports) {
                    def content = readFile(report.path)
                    def matcher = content =~ /tests="(\\d+)".*?failures="(\\d+)".*?errors="(\\d+)".*?skipped="(\\d+)"/
                    if (matcher) {
                        total += matcher[0][1].toInteger()
                        failed += matcher[0][2].toInteger() + matcher[0][3].toInteger()
                        skipped += matcher[0][4].toInteger()
                    }
                }
                if (total > 0) {
                    def passed = total - failed - skipped
                    def passRate = (passed * 100.0) / total
                    testData = """{
                        "totalTests": ${total},
                        "passed": ${passed},
                        "failed": ${failed},
                        "skipped": ${skipped},
                        "passRate": ${passRate}
                    }"""
                }
            } catch (Exception parseEx) {
                echo "Could not parse test results: ${parseEx.message}"
            }
        }

        def payload = """{
            "buildNumber": ${env.BUILD_NUMBER},
            "jobName": "${env.JOB_NAME}",
            "stage": "${stageName}",
            "status": "${status}",
            "duration": ${currentBuild.duration},
            "gitBranch": "${env.GIT_BRANCH ?: 'unknown'}",
            "gitCommit": "${env.GIT_COMMIT ?: 'unknown'}",
            "triggerType": "${currentBuild.getBuildCauses()[0]?.shortDescription ?: 'unknown'}",
            "jenkinsUrl": "${env.BUILD_URL ?: ''}",
            "timestamp": ${System.currentTimeMillis()},
            "testResults": ${testData},
            "metadata": {
              "buildTag": "${env.BUILD_TAG ?: ''}",
              "nodeName": "${env.NODE_NAME ?: ''}"
            }
        }"""

        httpRequest(
            url: env.WEBHOOK_URL,
            httpMode: 'POST',
            customHeaders: [[name: 'X-Jenkins-Webhook-Token', value: env.WEBHOOK_TOKEN, maskValue: true]],
            contentType: 'APPLICATION_JSON',
            requestBody: payload,
            validResponseCodes: '100:599',
            quiet: true
        )
    } catch (Exception e) {
        echo "Webhook notification failed for ${stageName}: ${e.message}"
    }
}
