{
  "info": {
    "name": "DevOps Platform API",
    "description": "Complete API test collection for DevOps Intelligence Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{BASE_URL}}" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"username\": \"testuser\", \"email\": \"test@example.com\", \"password\": \"password123\" }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns JWT token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"username\": \"testuser\", \"password\": \"password123\" }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns JWT token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"username\": \"testuser\", \"password\": \"wrongpassword\" }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Returns error', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Builds",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/builds?limit=20",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Pipeline Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/pipeline-status",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success is true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get System Metrics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/metrics",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has CPU data', () => pm.expect(pm.response.json().data).to.have.property('cpuUsage'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Docker Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/docker-status",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get K8s Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/k8s-status",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Build Analytics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/build-analytics",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has analytics', () => pm.expect(pm.response.json().data).to.have.property('totalBuilds'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Jenkins Webhook",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/webhook/jenkins",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"buildNumber\": 99, \"jobName\": \"test-job\", \"stage\": \"Build\", \"status\": \"SUCCESS\", \"duration\": 15000, \"gitBranch\": \"main\", \"gitCommit\": \"abc123\", \"triggerType\": \"push\", \"timestamp\": 1711234567890 }"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Actuator",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Prometheus Metrics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/prometheus"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contains metrics', () => pm.expect(pm.response.text()).to.include('jvm'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
